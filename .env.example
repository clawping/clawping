# ─────────────────────────────────────────────────────────
# ClawPing — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ─── Telegram ────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Default chat ID to send notifications to
# Get by messaging your bot then visiting:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=437734870

# ─── Email / SMTP ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# For Gmail: use an App Password, NOT your account password
# https://myaccount.google.com/apppasswords
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM="ClawPing <noreply@yourdomain.com>"

# Default recipient email for notifications
EMAIL_TO=you@yourdomain.com

# ─── Database ────────────────────────────────────────────
# SQLite (default). For PostgreSQL use:
# postgresql+asyncpg://user:password@localhost/clawping
DATABASE_URL=sqlite+aiosqlite:///./data/clawping.db

# ─── API Server ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Secret key for signing API tokens
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me-to-a-strong-random-secret

# ─── Scheduler ───────────────────────────────────────────
# IANA timezone for scheduled reminders
# Examples: UTC, Asia/Jakarta, America/New_York, Europe/London
SCHEDULER_TIMEZONE=UTC

# Max active pings allowed per user/token
MAX_PINGS_PER_USER=100

# Interval (seconds) to check condition-based alerts
CONDITION_CHECK_INTERVAL=60

# ─── CoinGecko ───────────────────────────────────────────
# Optional: CoinGecko API key for higher rate limits
# Leave empty to use the free public API
COINGECKO_API_KEY=

# ─── Debug ───────────────────────────────────────────────
# Set to "true" to enable verbose logging
DEBUG=false
